generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Product {
  id          Int     @id @default(autoincrement())
  nombre      String
  precio      Float
  categoria   String
  imagen      String?
  descripcion String?
  stock       Int     @default(0)
  @@map("product")
}

model User {
  id        Int        @id @default(autoincrement())
  nombre    String
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())
  purchases Purchase[]
  @@map("user")
}

model Purchase {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  items     Json
  total     Float
  createdAt DateTime @default(now())
  @@map("purchase")
}
